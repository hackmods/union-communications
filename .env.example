# Auth.js — required in production (openssl rand -base64 32)
AUTH_SECRET=
# Public URL of this deployment (no trailing slash)
AUTH_URL=http://localhost:3000

# Optional: force Auth.js trust host behind reverse proxies
# AUTH_TRUST_HOST=true

# ---------------------------------------------------------------------------
# MFA (Officer Hub confidential modules)
# Production: AUTH_MFA_MODE is required. Prefer totp.
# Demo/workshop hosts may set AUTH_MFA_MODE=shared_code_insecure and AUTH_MFA_CODE.
# Non-production defaults to shared_code_insecure with AUTH_DEV_MFA_CODE (or 000000).
# ---------------------------------------------------------------------------
# AUTH_MFA_MODE=totp
# AUTH_MFA_MODE=shared_code_insecure
# AUTH_MFA_CODE=
# AUTH_DEV_MFA_CODE=000000

# ---------------------------------------------------------------------------
# Postgres (Phase 6 / SEC-003) — optional until adapters are flipped
# Default backends remain memory. Set DATABASE_URL + *_DB_BACKEND=postgres to enable.
#
# Roles:
#   - Owner (POSTGRES_USER): migrations + db:seed — bypasses RLS
#   - App (unionops_app): runtime — RLS binds (migration 0008_app_role.sql)
# Prefer the app role for DATABASE_URL in production. Use the owner URL for
# MIGRATE_DATABASE_URL / npm run db:migrate / npm run db:seed.
# ---------------------------------------------------------------------------
# DATABASE_URL=postgres://unionops_app:CHANGE_ME@localhost:5432/unionops
# MIGRATE_DATABASE_URL=postgres://unionops:CHANGE_ME@localhost:5432/unionops
# POSTGRES_APP_PASSWORD=CHANGE_ME
# GRIEVANCE_DB_BACKEND=memory
# BUMPING_DB_BACKEND=memory
# AUDIT_DB_BACKEND=memory
# TIME_DB_BACKEND=memory
# ATTACHMENTS_DB_BACKEND=memory
# DISCUSSIONS_DB_BACKEND=memory
# TASKS_DB_BACKEND=memory
# INFORMAL_LOG_DB_BACKEND=memory
# MINUTES_DB_BACKEND=memory
# OFFICERS_DB_BACKEND=memory
# LEDGER_DB_BACKEND=memory
# TRAVEL_DB_BACKEND=memory
# COMMITTEES_DB_BACKEND=memory
# ELECTIONS_DB_BACKEND=memory
# After migrate: npm run db:seed
# Optional demo grievance: SEED_DEMO_CASES=true npm run db:seed
# Live checks (need Postgres + app role): npm run db:rls-smoke
#                          npm run db:durability-smoke  (also GRIEVANCE_DB_BACKEND=postgres)

# ---------------------------------------------------------------------------
# Attachments / documents object storage (FEAT-001)
# Bytes are written to local disk by default (not memory:// stubs).
# S3-compatible storage and ClamAV are stubbed/deferred — see docs/audit/execution-backlog.md.
# ---------------------------------------------------------------------------
# ATTACHMENT_STORAGE=local
# ATTACHMENT_LOCAL_DIR=.data/attachments
# ATTACHMENT_STORAGE=s3
# ATTACHMENT_SCAN_MODE=strict
# ATTACHMENT_SCANNER_URL=http://clamav:3310

# ---------------------------------------------------------------------------
# Officer Hub public launch (optional)
# When unset/false: hide header hub CTA and hub-forward marketing copy.
# `/app` stays reachable for demos and CI. Set true when launching publicly.
# Docker image builds default these to true for the current soft-launch host.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_OFFICER_HUB_PUBLIC=true

# ---------------------------------------------------------------------------
# Demo site banner (optional)
# When true: authenticated Officer Hub shows a persistent "Demo" banner so
# visitors know the instance is sample/demo data, not live production.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_DEMO_SITE=true

# ---------------------------------------------------------------------------
# Auth users (SEC-007)
# Production: demo roster is OFF unless NEXT_PUBLIC_DEMO_SITE or AUTH_ALLOW_DEMO_USERS.
# Set AUTH_USERS_BACKEND=postgres + DATABASE_URL to authenticate against `users`.
# ---------------------------------------------------------------------------
# AUTH_ALLOW_DEMO_USERS=true
# AUTH_USERS_BACKEND=memory
# AUTH_USERS_BACKEND=postgres

# ---------------------------------------------------------------------------
# Host brand defaults (optional — union-agnostic self-hosting)
# Precedence: these env vars → config/host-brand.json → platform orange
# Or run: npm run brand:set -- --primary=#CE1126 --local=79 --sub="Workers"
# Existing browser Brand Kits are unchanged until the user resets/imports.
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_BRAND_PRIMARY=#FF6B00
# NEXT_PUBLIC_BRAND_SECONDARY=#FFFFFF
# NEXT_PUBLIC_BRAND_ACCENT=#C2410C
# NEXT_PUBLIC_DEFAULT_LOCAL_NUMBER=
# NEXT_PUBLIC_DEFAULT_SUB_TEXT=Support Staff
# NEXT_PUBLIC_DEFAULT_DIVISION_ID=
