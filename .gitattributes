# Normalize line endings: LF in the repo, auto on checkout
* text=auto eol=lf

# Shell scripts must stay LF (they run in Linux containers)
*.sh text eol=lf

# Windows-specific scripts stay CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary assets — never touch
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
